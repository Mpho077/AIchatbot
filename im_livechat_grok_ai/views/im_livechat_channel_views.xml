<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Live Chat Channel Form View to add Grok AI Integration -->
    <record id="im_livechat_channel_view_form_grok_ai" model="ir.ui.view">
        <field name="name">im_livechat.channel.form.grok.ai</field>
        <field name="model">im_livechat.channel</field>
        <field name="inherit_id" ref="im_livechat.im_livechat_channel_view_form"/>
        <field name="arch" type="xml">
            <!-- Add Grok AI fields to Options page -->
            <page name="options" position="inside">
                <group string="Grok AI Integration">
                    <field name="grok_ai_enabled"/>
                    <field name="grok_ai_config_id" invisible="not grok_ai_enabled" required="grok_ai_enabled"/>
                </group>
            </page>
        </field>
    </record>
</odoo>
